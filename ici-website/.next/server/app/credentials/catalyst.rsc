21:T466,{"@context":"https://schema.org","@type":"Course","@id":"https://internationalcoachinginstitute.org/credentials/catalyst#course","name":"ICI Catalyst Coach Certification","description":"A catalyst is what makes change happen in others without being consumed by it. That is the work of a coach, and it is where your career begins. Over 36 hours of one-to-one work, you stop being someone who gives good advice and become someone who can genuinely coach: present, trusted, and skilled enough to hold another person's growth. You are coached individually throughout, so the learning is shaped around you. You finish ready to take your first clients with confidence rather than hope.","url":"https://internationalcoachinginstitute.org/credentials/catalyst","provider":{"@id":"https://internationalcoachinginstitute.org/#organization"},"courseMode":"online","educationalLevel":"Professional certification","timeRequired":"P3M","offers":{"@type":"Offer","price":"215000","priceCurrency":"INR","url":"https://internationalcoachinginstitute.org/checkout/catalyst","availability":"https://schema.org/InStock","validFrom":"2026-06-22"}}15:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$21"}}]
