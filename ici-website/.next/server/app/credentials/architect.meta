{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/credentials/layout,_N_T_/credentials/architect/layout,_N_T_/credentials/architect/page,_N_T_/credentials/architect"
  },
  "segmentPaths": [
