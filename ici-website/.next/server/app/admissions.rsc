18:["$","$L16",null,{"delay":0.2,"children":[["$","h3",null,{"className":"text-h3 text-brand-navy-900 mb-6 pb-4 border-b border-brand-navy-200","children":"Tuition and pricing"}],["$","p",null,{"className":"text-muted mb-6 text-body","children":"Every price is complete and set out plainly on our Pricing page, with instalment options available."}],["$","$L14",null,{"href":"/pricing","className":"btn-primary inline-flex","children":["See pricing"," ",["$","$L1b",null,{"ref":"$undefined","iconNode":"$17:props:children:2:props:children:2:props:iconNode","className":"lucide-chevron-right","size":18}]]}]]}]
19:["$","section",null,{"className":"relative w-full max-w-full overflow-x-hidden py-16 lg:py-24 relative z-20","children":["$","div",null,{"className":"max-w-[800px] mx-auto px-4 lg:px-8","children":[["$","$L16",null,{"className":"text-center mb-16","children":[["$","h2",null,{"className":"text-h2 text-brand-navy-900 mb-4","children":"Frequently asked questions"}],["$","div",null,{"className":"w-24 h-1 bg-brand-gold-500 mx-auto"}]]}],["$","$L1c",null,{"content":{"meta_title":"Admissions | International Coaching Institute","meta_description":"How to join ICI: choose your level, apply free, speak with an advisor and begin one-to-one coaching training online.","page_url":"/admissions","hero_eyebrow":"Admissions","hero_heading":"Joining ICI","hero_body":"Applying to ICI is meant to be human, not bureaucratic. There is no entrance exam and no long wait. We want to understand where you are, what you want to build, and which level will get you there, then help you take the next step with confidence. Here is exactly how it works.","how_to_apply_heading":"How to apply","apply_step_1":"Choose your level, or speak to an advisor if you are unsure.","apply_step_2":"Submit a short application. It takes a few minutes and costs nothing.","apply_step_3":"Speak with an advisor to confirm the right fit and answer your questions.","apply_step_4":"Confirm your place and complete enrolment, in full or by instalments.","apply_step_5":"Get matched with your coach and begin.","entry_requirements_heading":"Entry requirements","entry_requirements_body":"Catalyst is open to anyone serious about learning to coach, with no prior qualification required. Higher levels require the level below or equivalent experience, which we confirm with you.","assessment_heading":"Free assessment: which level is right for me?","assessment_body":"Not sure whether to start at Catalyst or higher? Our short, free assessment asks about your experience and goals and points you to the right starting place. No email wall, no pressure.","assessment_link_text":"Not sure where to start? Speak to an advisor","assessment_link_url":"/admissions/contact","tuition_heading":"Tuition and pricing","tuition_body":"Every price is complete and set out plainly on our Pricing page, with instalment options available.","tuition_link_text":"See pricing","tuition_link_url":"/pricing","faq_heading":"Frequently asked questions","faq_1_question":"Is the training live or self-paced?","faq_1_answer":"Live and one-to-one. You are coached individually in real time, with guided self-work between sessions. This is how coaching skill is actually built.","faq_2_question":"How long does it take?","faq_2_answer":"It depends on the level, from around three months for Catalyst to up to a year for Luminary. You will have a clear schedule before you enrol.","faq_3_question":"Can my organisation train a team?","faq_3_answer":"Yes. Speak to us about organisational and team training.","faq_4_question":"What are the entry requirements?","faq_4_answer":"Our foundation level, Catalyst, is open to anyone committed to learning to coach. The advanced levels (Architect, Sage, Luminary) require prior certification or equivalent experience, which we will discuss during your admissions conversation.","faq_5_question":"Is there an interview process?","faq_5_answer":"Yes. Before your enrolment is finalised, you will have a brief, informal conversation with an advisor. This is simply to ensure the pathway is the right fit for your goals and to answer any questions you have.","faq_6_question":"When can I start my training?","faq_6_answer":"Because our coaching is strictly one-to-one, we do not run fixed cohorts or intake dates. You can apply at any time, and you will typically begin your sessions within 7 working days of your enrolment being confirmed.","cta_button_1_text":"Start your application","cta_button_1_link":"/apply","cta_button_2_text":"Speak to an Advisor","cta_button_2_link":"/admissions/contact","custom_code":""},"defaults":{"heroEyebrow":"Admissions","heroHeading":"Joining ICI","heroBody":"Applying to ICI is meant to be human, not bureaucratic. There is no entrance exam and no long wait. We want to understand where you are, what you want to build, and which level will get you there, then help you take the next step with confidence. Here is exactly how it works.","howToApplyHeading":"How to apply","applySteps":["Choose your level, or speak to an advisor if you are unsure.","Submit a short application. It takes a few minutes and costs nothing.","Speak with an advisor to confirm the right fit and answer your questions.","Confirm your place and complete enrolment, in full or by instalments.","Get matched with your coach and begin."],"entryRequirementsHeading":"Entry requirements","entryRequirementsBody":"Catalyst is open to anyone serious about learning to coach, with no prior qualification required. Higher levels require the level below or equivalent experience, which we confirm with you.","assessmentHeading":"Free assessment: which level is right for me?","assessmentBody":"Not sure whether to start at Catalyst or higher? Our short, free assessment asks about your experience and goals and points you to the right starting place. No email wall, no pressure.","assessmentLinkText":"Not sure where to start? Speak to an advisor","assessmentLinkUrl":"/admissions/contact","tuitionHeading":"Tuition and pricing","tuitionBody":"Every price is complete and set out plainly on our Pricing page, with instalment options available.","tuitionLinkText":"See pricing","tuitionLinkUrl":"/pricing","faqHeading":"Frequently asked questions","faqs":[{"q":"Is the training live or self-paced?","a":"Live and one-to-one. You are coached individually in real time, with guided self-work between sessions. This is how coaching skill is actually built."},{"q":"How long does it take?","a":"It depends on the level, from around three months for Catalyst to up to a year for Luminary. You will have a clear schedule before you enrol."},{"q":"Can my organisation train a team?","a":"Yes. Speak to us about organisational and team training."},{"q":"What are the entry requirements?","a":"Our foundation level, Catalyst, is open to anyone committed to learning to coach. The advanced levels (Architect, Sage, Luminary) require prior certification or equivalent experience, which we will discuss during your admissions conversation."},{"q":"Is there an interview process?","a":"Yes. Before your enrolment is finalised, you will have a brief, informal conversation with an advisor. This is simply to ensure the pathway is the right fit for your goals and to answer any questions you have."},{"q":"When can I start my training?","a":"Because our coaching is strictly one-to-one, we do not run fixed cohorts or intake dates. You can apply at any time, and you will typically begin your sessions within 7 working days of your enrolment being confirmed."}],"ctaButton1Text":"Start your application","ctaButton1Link":"/apply","ctaButton2Text":"Speak to an Advisor","ctaButton2Link":"/admissions/contact"}}],"$L1d"]}]}]
1e:T6fc,{"@context":"https://schema.org","@type":"FAQPage","@id":"https://internationalcoachinginstitute.org/admissions#faq","mainEntity":[{"@type":"Question","name":"Is the training live or self-paced?","acceptedAnswer":{"@type":"Answer","text":"Live and one-to-one. You are coached individually in real time, with guided self-work between sessions. This is how coaching skill is actually built."}},{"@type":"Question","name":"How long does it take?","acceptedAnswer":{"@type":"Answer","text":"It depends on the level, from around three months for Catalyst to up to a year for Luminary. You will have a clear schedule before you enrol."}},{"@type":"Question","name":"Can my organisation train a team?","acceptedAnswer":{"@type":"Answer","text":"Yes. Speak to us about organisational and team training."}},{"@type":"Question","name":"What are the entry requirements?","acceptedAnswer":{"@type":"Answer","text":"Our foundation level, Catalyst, is open to anyone committed to learning to coach. The advanced levels (Architect, Sage, Luminary) require prior certification or equivalent experience, which we will discuss during your admissions conversation."}},{"@type":"Question","name":"Is there an interview process?","acceptedAnswer":{"@type":"Answer","text":"Yes. Before your enrolment is finalised, you will have a brief, informal conversation with an advisor. This is simply to ensure the pathway is the right fit for your goals and to answer any questions you have."}},{"@type":"Question","name":"When can I start my training?","acceptedAnswer":{"@type":"Answer","text":"Because our coaching is strictly one-to-one, we do not run fixed cohorts or intake dates. You can apply at any time, and you will typically begin your sessions within 7 working days of your enrolment being confirmed."}}]}15:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1e"}}]
