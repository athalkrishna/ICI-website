{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/terms/layout,_N_T_/terms/page,_N_T_/terms,cms:global,cms:page:/terms"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/terms/__PAGE__",
    "/terms",
    "/_index",
    "/_head"
  ]
}