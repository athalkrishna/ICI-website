"div",null,{"className":"w-8 h-[1px] bg-brand-gold-500"}],["$","h2",null,{"className":"text-h2 text-brand-navy-900","children":"Our story"}]]}]}]}],["$","div",null,{"className":"lg:col-span-8","children":["$","$L2",null,{"delay":0.1,"className":"prose prose-lg prose-brand max-w-3xl","children":["$","div",null,{"dangerouslySetInnerHTML":{"__html":"<p>ICI was created by a group of experienced coaches and educators who kept seeing the same gap. Plenty of coaching qualifications taught technique, but few taught the depth, self-awareness and rigour that distinguish a coach people trust. We built the institute to close that gap, with one unusual decision at its heart: we would teach coaching one-to-one, the way coaching itself is done, rather than herding people through a classroom.</p><p>Today we train coaches entirely online, one-to-one, for clients all over the world. Our graduates want more than a certificate. They want the judgement, the craft and the standing to do this work well.</p>"}}]}]}]]}]}]}]]}],[["$","script","script-0",{"src":"/_next/static/chunks/2tnyzjlsgejhu.js","async":true}]],["$","$L3",null,{"children":["$","$4",null,{"name":"Next.MetadataOutlet","children":"$@5"}]}]]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"9Wo4TzfW9Yevq2MGGuB8X"}
